# Ottieni la chiave su https://aistudio.google.com/apikey
GEMINI_API_KEY=inserisci_qui_la_tua_chiave

# API Key per la ricerca in tempo reale su Normattiva/Gazzetta Ufficiale (RAG).
# Ottieni la chiave su https://tavily.com
TAVILY_API_KEY=inserisci_qui_la_tua_chiave

# API Key per Groq (Llama 3.3 70B) come validatore anti-allucinazione.
# Ottieni la chiave su https://console.groq.com/keys
GROQ_API_KEY=inserisci_qui_la_tua_chiave

# API Key per OpenRouter (fallback estremo quando Gemini e Groq sono saturi).
# Ottieni la chiave su https://openrouter.ai/keys
OPENROUTER_API_KEY=inserisci_qui_la_tua_chiave
